        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezplatná verze uchovává v historii až %lld videí.\nOdemkněte pro přidávání videí bez omezení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gratisversionen gemmer op til %lld videoer i historikken.\nLås op for at tilføje ubegrænsede videoer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Gratisversion speichert bis zu %lld Videos im Verlauf.\nSchalte frei, um unbegrenzt Videos hinzuzufügen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η δωρεάν έκδοση διατηρεί έως %lld βίντεο στο ιστορικό.\nΞεκλειδώστε για απεριόριστα βίντεο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The free version keeps up to %lld videos in your history.\nUnlock to add unlimited videos."
